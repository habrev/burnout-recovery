# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=reset_project.settings.development

# Database (development)
DB_NAME=reset_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# Email (Gmail SMTP)
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=youremail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=youremail@gmail.com

# OTP expiry in minutes
OTP_EXPIRY_MINUTES=10

# Comma-separated emails that get admin/superuser on registration
ADMIN_EMAILS=you@gmail.com

# --- PRODUCTION ONLY (set on Render) ---
# DATABASE_URL=postgresql://...
# ALLOWED_HOSTS=yourapp.onrender.com
# CORS_ALLOWED_ORIGINS=https://yourfrontend.onrender.com
